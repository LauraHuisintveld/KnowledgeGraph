@prefix kgvocab: <https://laurahuisintveld.github.io/KnowledgeGraph/vocabulary.ttl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gn: <http://www.geonames.org/ontology#> .

kgvocab:Person a rdfs:Class ;
              rdfs:label "Person"@en ;
              rdfs:comment "A person is an human being that lives or lived at the earth."@en .

kgvocab:Terms a rdfs:Class ;
              rdfs:label "Terms"@en ;
              rdfs:comment "A term from wikidata."@en .

kgvocab:Photo a rdfs:Class ;
             rdfs:label "Photograph"@en ;
             rdfs:comment "A picture."@en . 

kgvocab:name a rdf:Property ;
            rdfs:label "Name"@en ;
            rdfs:comment "The name of a person."@en ;
            rdfs:domain kgvocab:Person ;
            rdfs:range xsd:string .

kgvocab:email a rdf:Property ;
            rdfs:label "Email"@en ;
            rdfs:comment "The e-mail address of a person."@en ;
            rdfs:domain kgvocab:Person ;
            rdfs:range xsd:string .

kgvocab:jobtitle a rdf:Property ;
                rdfs:label "Jobtitle"@en ;
                rdfs:comment "The job title of a person."@en ;
                rdfs:domain kgvocab:Person ;
                rdfs:range xsd:string .

kgvocab:affiliation a rdf:Property ;
                rdfs:label "Affiliation"@en ;
                rdfs:comment "The affiliation of a person."@en ;
                rdfs:domain kgvocab:Person ;
                rdfs:range xsd:string .

kgvocab:location a rdf:Property ;
                rdfs:label "Location"@en ;
                rdfs:comment "The location of a person."@en ;
                rdfs:domain kgvocab:Person ;
                rdfs:range gn:Feature .

kgvocab:interest a rdf:Property ;
                rdfs:label "Interest"@en ;
                rdfs:comment "A specific interest of a person."@en ;
                rdfs:domain kgvocab:Person ;
                rdfs:range kgvocab:Terms .

kgvocab:knows a rdf:Property ; 
              rdfs:label "Knows"@en ;
              rdfs:comment "Indicates connections of the Person."@en ;
              rdfs:domain kgvocab:Person ;
              rdfs:range kgvocab:Person .

kgvocab:title a rdf:Property ;
              rdfs:label "Title"@en ;
              rdfs:comment "The title of an photograph"@en ;
              rdfs:domain kgvocab:Photo ;
              rdfs:range xsd:string .
              
kgvocab:creator a rdf:Property ;
              rdfs:label "Creator"@en ;
              rdfs:comment "The creator or author of an photograph"@en ;
              rdfs:domain kgvocab:Photo ;
              rdfs:range kgvocab:Person .

kgvocab:subject a rdf:Property ;
              rdfs:label "Subject"@en ;
              rdfs:comment "The people who are depicted in a photograph"@en ;
              rdfs:domain kgvocab:Photo ;
              rdfs:range kgvocab:Person .

kgvocab:photolocation a rdf:Property ;
              rdfs:label "Photo Locations"@en ;
              rdfs:comment "The place where the photograph was taken"@en ;
              rdfs:domain kgvocab:Photo ;
              rdfs:range gn:Feature .

kgvocab:photoDescription a rdf:Property ;
              rdfs:label "Photo Description"@en ;
              rdfs:comment "The description of a photograph"@en ;
              rdfs:domain kgvocab:Photo ;
              rdfs:range xsd:string .

